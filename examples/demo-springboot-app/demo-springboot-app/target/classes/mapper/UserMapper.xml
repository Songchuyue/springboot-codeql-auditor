<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.audit.audit_spring_demo.mapper.UserMapper">

    <select id="searchByName" resultType="com.audit.audit_spring_demo.model.User">
        select id, username, email
        from users
        where username = #{username}
    </select>

    <select id="listOrderBy" resultType="com.audit.audit_spring_demo.model.User">
        select id, username, email
        from users
        order by ${orderBy}
    </select>
</mapper>
